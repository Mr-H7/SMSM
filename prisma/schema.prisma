generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
enum Role {
  OWNER
  SELLER
}

enum VariantGrade {
  ORIGINAL
  MIRROR
  EGYPTIAN
}

enum ReturnType {
  REFUND
  EXCHANGE
}

model User {
  id             String       @id @default(cuid())
  username       String       @unique
  fullName       String?
  role           Role         @default(SELLER)
  passwordHash   String
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  sales          Sale[]
  createdReturns SaleReturn[] @relation("ReturnCreatedBy")
}

model ProductModel {
  id        String   @id @default(cuid())
  name      String
  brand     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variants  ProductVariant[]
}

model ProductVariant {
  id               String                  @id @default(cuid())
  modelId          String
  grade            VariantGrade
  color            String?
  size             String?
  sku              String?                 @unique
  sellPrice        Int
  costPrice        Int
  stockQty         Int                     @default(0)
  isActive         Boolean                 @default(true)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  model            ProductModel            @relation(fields: [modelId], references: [id], onDelete: Cascade)
  items            SaleItem[]
  returnItems      SaleReturnItem[]
  replacementItems SaleReturnReplacement[]
}

model Sale {
  id          String       @id @default(cuid())
  sellerId    String
  customer    String?
  total       Int
  discount    Int          @default(0)
  createdAt   DateTime     @default(now())

  seller      User         @relation(fields: [sellerId], references: [id], onDelete: Restrict)
  items       SaleItem[]
  returns     SaleReturn[]
}

model SaleItem {
  id          String         @id @default(cuid())
  saleId      String
  variantId   String
  qty         Int
  sellPrice   Int
  costPrice   Int

  sale        Sale           @relation(fields: [saleId], references: [id], onDelete: Cascade)
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  returnItems SaleReturnItem[]
}

model SaleReturn {
  id                    String                  @id @default(cuid())
  saleId                String
  createdById           String
  type                  ReturnType
  reason                String?
  notes                 String?
  returnedGross         Int                     @default(0)
  returnedDiscountShare Int                     @default(0)
  returnedValue         Int                     @default(0)
  replacementValue      Int                     @default(0)
  refundAmount          Int                     @default(0)
  extraAmount           Int                     @default(0)
  createdAt             DateTime                @default(now())

  sale                  Sale                    @relation(fields: [saleId], references: [id], onDelete: Restrict)
  createdBy             User                    @relation("ReturnCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  items                 SaleReturnItem[]
  replacements          SaleReturnReplacement[]

  @@index([saleId, createdAt])
  @@index([createdById, createdAt])
}

model SaleReturnItem {
  id         String         @id @default(cuid())
  returnId   String
  saleItemId String
  variantId  String
  qty        Int
  unitPrice  Int
  lineTotal  Int
  createdAt  DateTime       @default(now())

  return     SaleReturn     @relation(fields: [returnId], references: [id], onDelete: Cascade)
  saleItem   SaleItem       @relation(fields: [saleItemId], references: [id], onDelete: Restrict)
  variant    ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@index([returnId])
  @@index([saleItemId])
  @@index([variantId])
}

model SaleReturnReplacement {
  id         String         @id @default(cuid())
  returnId   String
  variantId  String
  qty        Int
  unitPrice  Int
  lineTotal  Int
  createdAt  DateTime       @default(now())

  return     SaleReturn     @relation(fields: [returnId], references: [id], onDelete: Cascade)
  variant    ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@index([returnId])
  @@index([variantId])
}